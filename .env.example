# ============================================================================
# Web Scraper Platform – Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your environment.

# ── Application ────────────────────────────────────────────────────────────
APP_NAME="Web Scraper Platform"
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development
API_PREFIX=/api/v1

# ── Database (MySQL) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=web_scraper_db
DB_DIALECT=mysql
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ── AI Extraction (DeepSeek) ────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
AI_EXTRACTION_ENABLED=true

# ── Scraper Settings ───────────────────────────────────────────────────────
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF_FACTOR=2.0
SCRAPER_CRAWL_DEPTH=2
SCRAPER_MAX_URLS_PER_JOB=500
SCRAPER_RESPECT_ROBOTS_TXT=true
SCRAPER_USER_AGENT_ROTATION=true
SCRAPER_HEADLESS_BROWSER=true
SCRAPER_CONCURRENT_REQUESTS=5

# ── Proxy (optional) ───────────────────────────────────────────────────────
PROXY_ENABLED=false
PROXY_LIST=

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── File Upload ────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO


